# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME=CodeJudge
DEBUG=false
SECRET_KEY=supersecretkey123

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://codejudge:codejudge@db:5432/codejudge
DATABASE_URL_SYNC=postgresql://codejudge:codejudge@db:5432/codejudge

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── AWS ────────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET=codejudge-testcases

# ── Sandbox Images ─────────────────────────────────────────────────────────────
SANDBOX_IMAGE_CPP=codejudge-cpp
SANDBOX_IMAGE_PYTHON=codejudge-python
SANDBOX_IMAGE_JAVA=codejudge-java

# ── Worker ─────────────────────────────────────────────────────────────────────
WORKER_THREADS=4
